# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nexusgrid
POSTGRES_USER=nexus
POSTGRES_PASSWORD=supersecretpassword

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redissecret

# ─── MinIO ────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=nexusgrid-files
MINIO_USE_SSL=false

# ─── Backend ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
CACHE_TTL_SECONDS=60
